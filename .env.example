# SYS / SYSTEM password — used by the DB container.
ORACLE_PASSWORD=oracle_sys_pw

# App user that owns the schema. The Flask app connects as this user.
APP_USER=dscae
APP_USER_PASSWORD=dscae123

# Flask connection — keep DB_USER/DB_PASSWORD in sync with APP_USER/APP_USER_PASSWORD.
DB_USER=dscae
DB_PASSWORD=dscae123
DB_HOST=db
DB_PORT=1521
DB_SERVICE=FREEPDB1

DB_POOL_MIN=1
DB_POOL_MAX=8

# Required. Sessions break across gunicorn workers without it.
FLASK_SECRET_KEY=change-me-in-prod

# Host port for the web app. macOS AirPlay Receiver squats on 5000, so 5050 default.
PORT=5050

# Gunicorn tuning.
WEB_CONCURRENCY=2
WEB_TIMEOUT=60
